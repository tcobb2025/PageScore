# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google PageSpeed Insights (optional, works without key but rate-limited)
PAGESPEED_API_KEY=

# Instantly.ai for cold email sending
INSTANTLY_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PAYMENT_LINK=https://buy.stripe.com/...

# Resend for PDF delivery emails
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reports@yourdomain.com

# SerpAPI for Google Maps scraping (used as fallback or when SCRAPER_MODE=serpapi)
SERPAPI_KEY=

# Scraper config
# SCRAPER_MODE: "auto" (try Playwright first, fall back to SerpAPI),
#               "playwright" (Playwright only), "serpapi" (SerpAPI only)
SCRAPER_MODE=auto
# Residential proxy for Playwright scraping (optional, recommended for high volume)
# Format: http://user:pass@host:port  or  socks5://user:pass@host:port
PROXY_URL=
# Delay between scraping each business listing (seconds, randomized between min and max)
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=3.5

# App config
REPORT_BASE_URL=https://yourdomain.com/reports
FLASK_PORT=5000
DAILY_EMAIL_LIMIT=50
